package admin

import "github.com/everyday-studio/ollm/internal/domain"
import "github.com/everyday-studio/ollm/view/layout"
import "fmt"

templ UsersPage(data *domain.PaginatedData[domain.User], adminPath string, bucketName string) {
	@layout.Base("Users Management", adminPath, "users") {
		<div class="w-full max-w-7xl mx-auto">
			<script>
				function uploadImage(type, refId, inputEl) {
					if (!inputEl.files || inputEl.files.length === 0) return;
					const formData = new FormData();
					formData.append('type', type);
					formData.append('ref_id', refId);
					formData.append('file', inputEl.files[0]);
					fetch('/upload/image', { method: 'POST', body: formData })
						.then(res => {
							if (res.ok) window.location.reload();
							else alert('Upload failed');
						})
						.catch(err => alert('Error: ' + err));
				}
			</script>
			<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
				<h1 class="text-3xl font-bold text-white">Users</h1>
			</div>
			<div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-lg">
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-gray-700">
						<thead class="bg-gray-900">
							<tr>
								<th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">ID</th>
								<th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Name</th>
								<th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Email</th>
								<th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Role</th>
								<th class="px-6 py-4 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Created At</th>
							</tr>
						</thead>
						<tbody id="users-table-body" class="bg-gray-800 divide-y divide-gray-700">
							@UserTableRows(data, adminPath, bucketName)
						</tbody>
					</table>
				</div>
			</div>
		</div>
	}
}

templ UserTableRows(data *domain.PaginatedData[domain.User], adminPath string, bucketName string) {
	if len(data.Data) == 0 {
		<tr>
			<td colspan="5" class="px-6 py-8 text-center text-gray-500">
				No users found.
			</td>
		</tr>
	} else {
		for _, user := range data.Data {
			<tr class="hover:bg-gray-700/50 transition-colors group">
				<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400 font-mono">
					<div class="flex items-center gap-2">
						<span>{ user.ID }</span>
						<button data-copy-id={ user.ID } onclick="copyToClipboard(this.getAttribute('data-copy-id'), this)" class="p-1 hover:bg-gray-600 rounded transition-colors text-gray-500 hover:text-gray-300 opacity-0 group-hover:opacity-100" title="Copy ID">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
							</svg>
						</button>
					</div>
				</td>
				<td class="px-6 py-4 whitespace-nowrap text-sm text-white font-medium flex items-center gap-2">
					<div class="relative group/avatar cursor-pointer shrink-0">
						<img src={ fmt.Sprintf("https://storage.googleapis.com/%s/user/%s.png", bucketName, user.ID) } 
							onerror="this.onerror=null; this.outerHTML=`<div class='h-8 w-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-xs font-bold shadow-inner'>${this.getAttribute('data-initial')}</div>`;"
							data-initial={ string([]rune(user.Name)[0:1]) }
							class="h-8 w-8 rounded-full object-cover shadow-inner bg-gray-900" />
						<button { templ.Attributes{"onclick": fmt.Sprintf("document.getElementById('upload-user-%s').click()", user.ID)}... } class="absolute inset-0 bg-black/60 rounded-full flex items-center justify-center opacity-0 group-hover/avatar:opacity-100 transition-opacity" title="Upload Profile Pic">
							<svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
						</button>
						<input type="file" id={ fmt.Sprintf("upload-user-%s", user.ID) } class="hidden" accept="image/*" { templ.Attributes{"onchange": fmt.Sprintf("uploadImage('user', '%s', this)", user.ID)}... } />
					</div>
					{ user.Name }
				</td>
				<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">{ user.Email }</td>
				<td class="px-6 py-4 whitespace-nowrap text-sm">
					if user.Role == domain.RoleAdmin {
						<span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-500/20 text-purple-400 border border-purple-500/30">
							Admin
						</span>
					} else {
						<span class="px-2.5 py-1 inline-flex text-xs leading-5 font-regular rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20">
							{ string(user.Role) }
						</span>
					}
				</td>
				<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400">{ user.CreatedAt.Format("2006-01-02 15:04") }</td>
			</tr>
		}
	}
	<tr id="pagination-row" class="bg-gray-900/50">
		<td colspan="5" class="px-6 py-4 border-t border-gray-700">
			<div class="flex items-center justify-between">
				<span class="text-sm text-gray-400">
					Showing page <span class="font-medium text-white">{ fmt.Sprintf("%d", data.Page) }</span> of <span class="font-medium text-white">{ fmt.Sprintf("%d", data.TotalPages) }</span> <span class="text-gray-500">(Total: { fmt.Sprintf("%d", data.Total) })</span>
				</span>
				<div class="flex gap-2">
					if data.Page > 1 {
						<button hx-get={ string(templ.URL(fmt.Sprintf("%s/users?page=%d&limit=%d", adminPath, data.Page-1, data.Limit))) } hx-target="#users-table-body" hx-swap="innerHTML" class="px-4 py-2 bg-gray-800 border border-gray-600 hover:border-blue-500 hover:text-blue-400 text-gray-300 rounded-lg text-sm transition-all focus:outline-none focus:ring-2 focus:ring-blue-500/50 flex items-center gap-1">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
							Prev
						</button>
					} else {
						<button disabled class="px-4 py-2 bg-gray-900 border border-gray-800 text-gray-600 rounded-lg text-sm cursor-not-allowed flex items-center gap-1">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
							Prev
						</button>
					}
					
					if data.Page < data.TotalPages {
						<button hx-get={ string(templ.URL(fmt.Sprintf("%s/users?page=%d&limit=%d", adminPath, data.Page+1, data.Limit))) } hx-target="#users-table-body" hx-swap="innerHTML" class="px-4 py-2 bg-gray-800 border border-gray-600 hover:border-blue-500 hover:text-blue-400 text-gray-300 rounded-lg text-sm transition-all focus:outline-none focus:ring-2 focus:ring-blue-500/50 flex items-center gap-1">
							Next
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
						</button>
					} else {
						<button disabled class="px-4 py-2 bg-gray-900 border border-gray-800 text-gray-600 rounded-lg text-sm cursor-not-allowed flex items-center gap-1">
							Next
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
						</button>
					}
				</div>
			</div>
		</td>
	</tr>
}
