package admin

import "github.com/everyday-studio/ollm/view/layout"
import "fmt"

templ Dashboard(adminName string, totalUsers int, totalGames int, activeMatches int, adminPath string) {
	@layout.Base("Admin Dashboard", adminPath, "dashboard") {
		<div class="w-full max-w-7xl mx-auto">
			
			<!-- Header Section -->
			<div class="mb-8 p-6 bg-gradient-to-r from-gray-800 to-gray-700 rounded-xl shadow-lg border border-gray-600 flex items-center justify-between">
				<div>
					<h1 class="text-3xl font-bold text-white mb-2">Dashboard</h1>
					<p class="text-gray-300 text-lg">
						환영합니다, <span class="font-semibold text-brand">{ adminName }</span> 요원님
					</p>
				</div>
				<div class="hidden sm:block">
					<div class="h-16 w-16 bg-gray-900 rounded-full flex items-center justify-center border-2 border-brand shadow-[0_0_15px_rgba(59,130,246,0.5)]">
						<svg class="h-8 w-8 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
						</svg>
					</div>
				</div>
			</div>

			<!-- Stats Grid -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
				
				<!-- Total Users Card -->
				<div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-md hover:shadow-lg hover:border-blue-500/50 transition-all duration-300 group">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-medium text-gray-400 mb-1">Total Users</p>
							<p class="text-4xl font-bold text-white group-hover:text-blue-400 transition-colors">
								{ fmt.Sprintf("%d", totalUsers) }
							</p>
						</div>
						<div class="p-3 bg-gray-900/50 rounded-lg group-hover:bg-blue-500/20 transition-colors">
							<svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
					</div>
					<div class="mt-4 flex items-center text-sm">
						<span class="text-green-400 font-medium flex items-center">
							<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
							Active
						</span>
						<span class="text-gray-500 ml-2">Total registered users</span>
					</div>
				</div>

				<!-- Total Games Card -->
				<div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-md hover:shadow-lg hover:border-purple-500/50 transition-all duration-300 group">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-medium text-gray-400 mb-1">Total Games</p>
							<p class="text-4xl font-bold text-white group-hover:text-purple-400 transition-colors">
								{ fmt.Sprintf("%d", totalGames) }
							</p>
						</div>
						<div class="p-3 bg-gray-900/50 rounded-lg group-hover:bg-purple-500/20 transition-colors">
							<svg class="w-8 h-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
							</svg>
						</div>
					</div>
					<div class="mt-4 flex items-center text-sm">
						<span class="text-green-400 font-medium flex items-center">
							<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
							Playable
						</span>
						<span class="text-gray-500 ml-2">Live scenarios</span>
					</div>
				</div>

				<!-- Active Matches Card -->
				<div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-md hover:shadow-lg hover:border-emerald-500/50 transition-all duration-300 group">
					<div class="flex items-center justify-between">
						<div>
							<p class="text-sm font-medium text-gray-400 mb-1">Active Matches</p>
							<p class="text-4xl font-bold text-white group-hover:text-emerald-400 transition-colors">
								{ fmt.Sprintf("%d", activeMatches) }
							</p>
						</div>
						<div class="p-3 bg-gray-900/50 rounded-lg group-hover:bg-emerald-500/20 transition-colors">
							<svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
					</div>
					<div class="mt-4 flex items-center text-sm">
						<span class="text-emerald-400 font-medium flex items-center">
							<span class="relative flex h-3 w-3 mr-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
								<span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
							</span>
							Live Now
						</span>
						<span class="text-gray-500 ml-2">Users playing</span>
					</div>
				</div>

			</div>
			
			<!-- Getting Started Panel -->
			<div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
				<h2 class="text-xl font-bold text-white mb-4 flex items-center">
					<svg class="h-6 w-6 text-brand mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					System Status
				</h2>
				<div class="space-y-4">
					<div class="flex items-center p-4 bg-gray-900/50 rounded-lg border border-gray-700">
						<div class="w-3 h-3 rounded-full bg-emerald-500 mr-4 shadow-[0_0_8px_rgba(16,185,129,0.8)]"></div>
						<div>
							<h3 class="text-white font-medium">Database Connection</h3>
							<p class="text-sm text-gray-400">PostgreSQL is operational</p>
						</div>
					</div>
					<div class="flex items-center p-4 bg-gray-900/50 rounded-lg border border-gray-700">
						<div class="w-3 h-3 rounded-full bg-emerald-500 mr-4 shadow-[0_0_8px_rgba(16,185,129,0.8)]"></div>
						<div>
							<h3 class="text-white font-medium">LLM API</h3>
							<p class="text-sm text-gray-400">OpenAI integration is active</p>
						</div>
					</div>
				</div>
			</div>

		</div>
	}
}
